# NOTE: git does NOT support inline (end-of-line) comments in .gitignore.
# Every comment must be on its own line, or the pattern is taken literally.

# Generated by install.ps1
launcher.ps1
install.log
pip.log

# Isolated per-machine Claude Code config/state for the local instance
.claude-local/

# Downloaded / built artifacts (large, machine-specific)
models/
llama.cpp/
venv/

# Scratch / temporary helper scripts
_*.ps1
*.tmp
*.test.ps1

# OS / editor cruft
Thumbs.db
desktop.ini
.vs/
.vscode/
