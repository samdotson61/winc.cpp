# NOTE: git does NOT support inline (end-of-line) comments in .gitignore.

# Built winc binary + cross-compile output
/winc
/winc.exe
/winc.exe~
*~
/dist/

# Self-rebuild swap artifacts ('winc update' on a clone)
/winc.new
/winc.old
/winc.exe.new
/winc.exe.old

# Single config file (per-machine; generated from the embedded default template)
/winc.toml

# On-disk catalog cache written by 'winc update' (overrides the embedded catalog).
# NOTE: only the install-root copy; the source of truth is internal/catalog/catalog.json
/catalog.json

# Downloaded / generated runtime artifacts (large, machine-specific)
/bin/
/models/
/.claude-local/
/.winc-dl/
/llama-swap.yaml
*.log

# Legacy stack (no longer used; kept out of the tree)
/venv/
/llama.cpp/

# Internal roadmap (planning doc, not shipped)
wincmap.md

# OS / editor cruft
Thumbs.db
desktop.ini
.DS_Store
.vs/
.vscode/
__pycache__/
*.pyc
